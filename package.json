{
  "name": "project-baller-backend",
  "version": "1.0.0",
  "description": "Backend API for Project Baller",
  "private": true,
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "check": "node -e \"const fs=require('fs');const path=require('path');const cp=require('child_process');const walk=(dir)=>fs.readdirSync(dir,{withFileTypes:true}).flatMap(d=>d.isDirectory()?walk(path.join(dir,d.name)):d.name.endsWith('.js')?[path.join(dir,d.name)]:[]);for(const file of walk('src'))cp.execFileSync(process.execPath,['--check',file],{stdio:'inherit'});\"",
    "lint": "npm run check"
  },
  "keywords": [
    "project-baller",
    "express",
    "mongodb",
    "openai",
    "football",
    "flutter",
    "api"
  ],
  "author": "Project Baller",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "openai": "^4.56.0",
    "socket.io": "^4.7.5",
    "stripe": "^16.5.0",
    "uuid": "^10.0.0",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
